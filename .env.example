# ─── JWT signing ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# ─── Wibiz → Propfunded webhook auth (Wibiz calls Propfunded's endpoint) ─────
WIBIZ_API_KEY=replace_with_api_key_provided_by_wibiz

# ─── Propfunded subscriber API (set once Dusan shares the URL) ───────────────
PROPFUNDED_API_URL=https://api.propfunded.ai
PROPFUNDED_API_KEY=replace_with_key_agreed_with_propfunded

# ─── Propfunded → Wibiz webhook (Propfunded fires this when data changes) ────
PROPFUNDED_WEBHOOK_SECRET=replace_with_shared_secret_for_incoming_webhooks

# ─── GoHighLevel ─────────────────────────────────────────────────────────────
GHL_API_KEY=pit-xxxx
GHL_LOCATION_ID=xxxx

# ─── Admin (manual sync trigger) ─────────────────────────────────────────────
ADMIN_SECRET=replace_with_strong_admin_secret

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
