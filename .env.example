# ─── JWT signing ──────────────────────────────────────────────────────────────
# Shared secret used to sign subscriber JWTs (HS256).
# Exchange this with Wibiz.ai through a secure channel — NOT email or Slack.
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# ─── Wibiz webhook auth ───────────────────────────────────────────────────────
# API key that Wibiz.ai sends in the Authorization: Bearer header when calling
# GET /api/wibiz/subscriber/:id. Wibiz.ai provides this value during onboarding.
WIBIZ_API_KEY=replace_with_api_key_provided_by_wibiz

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
